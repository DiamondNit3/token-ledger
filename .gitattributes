# Preserve byte-exact upstream/generated license text while keeping diff
# whitespace checks useful for hand-maintained files.
RUST-1.88-STANDARD-LIBRARY-NOTICES.html whitespace=-trailing-space
THIRD-PARTY-NOTICES.html whitespace=-trailing-space
